# Copy this file to .env and replace only the values that apply to your local
# runtime. Do not commit .env, API keys, model IDs, or customer material.
PORT=3100

# Generic OpenAI-compatible local model configuration.
LOCAL_MODEL_ENABLED=true
LOCAL_MODEL_PROVIDER=openai-compatible
LOCAL_MODEL_BASE_URL=http://127.0.0.1:8080/api
LOCAL_MODEL_API_KEY=
LOCAL_MODEL_ID=
LOCAL_MODEL_TIMEOUT_MS=120000
LOCAL_MODEL_SUPPORTS_JSON_SCHEMA=true
LOCAL_MODEL_MAX_REPAIR_ATTEMPTS=1
